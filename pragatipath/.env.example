GEMINI_API_KEY=AIzaSyD32yLV3d-Ox8mBVQAOv3HWjH3x_4O_CcA

# ── Firebase (Production) ──────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your apps → Web app
# Leave blank in local dev (uses firebase-applet-config.json as fallback)
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_FIRESTORE_DB=(default)

# ── App URL (for QR codes) ─────────────────────────────────────────
# Set to your Render/Vercel URL after deploying
VITE_APP_URL=https://pragatipath.onrender.com

# ── Optional ───────────────────────────────────────────────────────
VITE_OPENWEATHER_API_KEY=
